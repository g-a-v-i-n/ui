{
  "name": "ui",
  "version": "0.0.1",
  "description": "",
  "main": "index.js",
  "private": false,
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    "./css/base.css": "./dist/css/base.css",
    "./primitives": {
      "types": "./dist/primitives.d.ts",
      "import": "./dist/primitives.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    }
  },
  "scripts": {
    "build": "pnpm build:js && pnpm build:css",
    "build:js": "(tsc || true) && tsc-alias",
    "build:css": "copyfiles -u 1 src/**/*.css src/**/**/*.css dist",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist/* tsconfig.tsbuildinfo"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "peerDependencies": {
    "@types/react": "*",
    "@types/react-dom": "*",
    "react": "^19.0",
    "react-dom": "^19.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/css-modules": "*",
    "@types/node": "*",
    "copyfiles": "^2.4.1",
    "hast-util-to-estree": "^3.1.3",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "typescript": "*"
  },
  "dependencies": {
    "@radix-ui/colors": "^3.0.0",
    "allotment": "^1.20.5",
    "motion": "^12.40.0",
    "radix-ui": "^1.5.0",
    "react-colorful": "^5.7.0"
  }
}
